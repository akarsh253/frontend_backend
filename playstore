<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>FOUNDX – Google Play Store</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Roboto', sans-serif; }
  body { background: #f8f9fa; display: flex; justify-content: center; padding: 24px 16px; min-height: 100vh; }
  .ps-root { background: #fff; border: 1px solid #e0e0e0; border-radius: 12px; overflow: hidden; max-width: 480px; width: 100%; }
  .ps-topbar { background: #1a73e8; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
  .ps-search { flex: 1; background: white; border-radius: 24px; padding: 8px 16px; display: flex; align-items: center; gap: 8px; }
  .ps-search span { font-size: 13px; color: #555; flex: 1; }
  .ps-hero { display: flex; align-items: flex-start; gap: 14px; padding: 20px 16px 12px; }
  .ps-icon { width: 80px; height: 80px; border-radius: 18px; background: linear-gradient(135deg, #0f1724 0%, #1a2a4a 100%); display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid #e0e0e0; position: relative; overflow: hidden; }
  .ps-icon-inner { color: white; font-size: 28px; font-weight: 700; letter-spacing: -1px; }
  .ps-icon-accent { position: absolute; bottom: -8px; right: -8px; width: 36px; height: 36px; background: #f7a600; border-radius: 50%; opacity: 0.6; }
  .ps-title-block { flex: 1; padding-top: 4px; }
  .ps-app-name { font-size: 20px; font-weight: 500; color: #202124; line-height: 1.2; }
  .ps-dev { font-size: 13px; color: #1a73e8; margin-top: 4px; }
  .ps-category { font-size: 12px; color: #5f6368; margin-top: 3px; }
  .ps-contains-ads { font-size: 11px; color: #9aa0a6; margin-top: 2px; }
  .ps-rating-row { display: flex; align-items: center; gap: 20px; padding: 10px 16px 14px; border-bottom: 1px solid #e0e0e0; }
  .ps-stat { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .ps-stat-val { font-size: 14px; font-weight: 500; color: #202124; }
  .ps-stat-lbl { font-size: 11px; color: #5f6368; }
  .ps-divider { width: 1px; height: 30px; background: #e0e0e0; }
  .ps-stars { color: #f7a600; font-size: 13px; letter-spacing: 1px; }
  .ps-install-row { padding: 14px 16px; display: flex; gap: 10px; align-items: center; }
  .ps-btn-install { flex: 1; background: #1a73e8; color: white; border: none; border-radius: 24px; padding: 12px; font-size: 15px; font-weight: 500; cursor: pointer; transition: background 0.15s; }
  .ps-btn-install:hover { background: #1558b0; }
  .ps-btn-install:disabled { background: #9aa0a6; cursor: default; }
  .ps-btn-open { flex: 1; background: transparent; color: #1a73e8; border: 1.5px solid #1a73e8; border-radius: 24px; padding: 12px; font-size: 15px; font-weight: 500; cursor: pointer; display: none; }
  .ps-btn-wish { width: 44px; height: 44px; border-radius: 50%; border: 1px solid #dadce0; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #5f6368; font-size: 18px; }
  .ps-progress { display: none; height: 4px; background: #e8eaed; border-radius: 2px; margin: 0 16px 12px; overflow: hidden; }
  .ps-progress-bar { height: 100%; width: 0%; background: #1a73e8; border-radius: 2px; transition: width 0.1s linear; }
  .ps-progress.visible { display: block; }
  .ps-screenshots { padding: 14px 16px; border-top: 1px solid #e0e0e0; }
  .ps-section-title { font-size: 14px; font-weight: 500; color: #202124; margin-bottom: 10px; }
  .ps-thumbs { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; }
  .ps-thumb { width: 120px; height: 200px; border-radius: 10px; flex-shrink: 0; border: 1px solid #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #9aa0a6; }
  .ps-thumb-1 { background: #0f1724; color: #cde; }
  .ps-thumb-2 { background: #1a2a4a; color: #bdf; }
  .ps-thumb-3 { background: #0b1018; color: #cde; }
  .ps-about { padding: 14px 16px; border-top: 1px solid #e0e0e0; }
  .ps-about-text { font-size: 13px; color: #5f6368; line-height: 1.6; }
  .ps-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .ps-tag { font-size: 11px; background: #f1f3f4; color: #5f6368; padding: 4px 10px; border-radius: 12px; border: 1px solid #e0e0e0; }
</style>
</head>
<body>
<div class="ps-root">

  <!-- Top bar -->
  <div class="ps-topbar">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
      <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
    </svg>
    <div class="ps-search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#555">
        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
      </svg>
      <span>foundx</span>
    </div>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
      <circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/><circle cx="5" cy="12" r="2"/>
    </svg>
  </div>

  <!-- App hero -->
  <div class="ps-hero">
    <div class="ps-icon">
      <div class="ps-icon-accent"></div>
      <div class="ps-icon-inner">FX</div>
    </div>
    <div class="ps-title-block">
      <div class="ps-app-name">FOUNDX</div>
      <div class="ps-dev">FoundX Inc.</div>
      <div class="ps-category">Business &amp; Productivity</div>
      <div class="ps-contains-ads">Free · Contains ads</div>
    </div>
  </div>

  <!-- Rating row -->
  <div class="ps-rating-row">
    <div class="ps-stat">
      <div class="ps-stat-val">4.6 <span class="ps-stars">★</span></div>
      <div class="ps-stat-lbl">52K reviews</div>
    </div>
    <div class="ps-divider"></div>
    <div class="ps-stat">
      <div class="ps-stat-val">1M+</div>
      <div class="ps-stat-lbl">Downloads</div>
    </div>
    <div class="ps-divider"></div>
    <div class="ps-stat">
      <div class="ps-stat-val">3+</div>
      <div class="ps-stat-lbl">Rated for</div>
    </div>
    <div class="ps-divider"></div>
    <div class="ps-stat">
      <div class="ps-stat-val">24 MB</div>
      <div class="ps-stat-lbl">Size</div>
    </div>
  </div>

  <!-- Install button -->
  <div class="ps-install-row" id="installRow">
    <button class="ps-btn-install" id="installBtn" onclick="startInstall()">Install</button>
    <button class="ps-btn-open" id="openBtn" onclick="alert('Opening FOUNDX...')">Open</button>
    <button class="ps-btn-wish" title="Add to wishlist">♡</button>
  </div>

  <!-- Progress bar -->
  <div class="ps-progress" id="progressWrap">
    <div class="ps-progress-bar" id="progressBar"></div>
  </div>

  <!-- Screenshots -->
  <div class="ps-screenshots">
    <div class="ps-section-title">Screenshots</div>
    <div class="ps-thumbs">
      <div class="ps-thumb ps-thumb-1" style="display:flex;flex-direction:column;gap:6px;padding:12px;">
        <div style="width:60%;height:8px;background:rgba(255,255,255,0.15);border-radius:4px;"></div>
        <div style="width:90%;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;"></div>
        <div style="width:75%;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;"></div>
        <div style="flex:1;background:rgba(26,115,232,0.3);border-radius:8px;margin-top:6px;"></div>
      </div>
      <div class="ps-thumb ps-thumb-2" style="display:flex;flex-direction:column;gap:6px;padding:12px;">
        <div style="flex:1;background:rgba(247,166,0,0.25);border-radius:8px;"></div>
        <div style="width:80%;height:8px;background:rgba(255,255,255,0.1);border-radius:4px;"></div>
        <div style="width:60%;height:8px;background:rgba(255,255,255,0.06);border-radius:4px;"></div>
      </div>
      <div class="ps-thumb ps-thumb-3" style="display:flex;flex-direction:column;gap:6px;padding:12px;">
        <div style="width:50%;height:8px;background:rgba(255,255,255,0.12);border-radius:4px;"></div>
        <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:4px;">
          <div style="background:rgba(26,115,232,0.4);border-radius:6px;"></div>
          <div style="background:rgba(247,166,0,0.3);border-radius:6px;"></div>
          <div style="background:rgba(247,166,0,0.2);border-radius:6px;"></div>
          <div style="background:rgba(26,115,232,0.25);border-radius:6px;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- About -->
  <div class="ps-about">
    <div class="ps-section-title">About this app</div>
    <div class="ps-about-text">
      FOUNDX helps founders, entrepreneurs, and startup teams manage their journey from idea to launch.
      Track milestones, connect with investors, and build your dream team — all in one place.
    </div>
    <div class="ps-tags">
      <span class="ps-tag">Startup</span>
      <span class="ps-tag">Founders</span>
      <span class="ps-tag">Productivity</span>
      <span class="ps-tag">Networking</span>
      <span class="ps-tag">MVP builder</span>
    </div>
  </div>

</div>

<script>
  function startInstall() {
    const btn = document.getElementById('installBtn');
    const progressWrap = document.getElementById('progressWrap');
    const progressBar = document.getElementById('progressBar');
    const openBtn = document.getElementById('openBtn');

    btn.textContent = 'Downloading...';
    btn.disabled = true;
    progressWrap.classList.add('visible');

    let progress = 0;
    const interval = setInterval(() => {
      progress += Math.random() * 8 + 3;
      if (progress >= 100) {
        progress = 100;
        clearInterval(interval);
        progressBar.style.width = '100%';
        setTimeout(() => {
          progressWrap.classList.remove('visible');
          btn.style.display = 'none';
          openBtn.style.display = 'block';
        }, 400);
      }
      progressBar.style.width = progress + '%';
    }, 150);
  }
</script>
</body>
</html>

  .mpm-schedule-row { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 0.82rem; }
  .mpm-schedule-row:last-child { border-bottom: none; }
  .mpm-schedule-day { color: var(--text2); font-weight: 600; }
  .mpm-schedule-time { color: var(--green); }

  /* ══════════════════════
     MENTOR REQUEST MODAL
  ══════════════════════ */
  .request-modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 700;
    background: rgba(4,8,4,0.9); backdrop-filter: blur(16px);
    align-items: center; justify-content: center; padding: 20px;
  }
  .request-modal-overlay.open { display: flex; animation: fadeIn 0.2s ease; }
  .request-modal {
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: 20px; width: 100%; max-width: 480px;

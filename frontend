  .mc-verified { background: var(--green); color: #000; font-size: 0.5rem; font-weight: 900; width: 13px; height: 13px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }
  .mc-title { font-size: 0.8rem; color: var(--text2); margin-bottom: 8px; }
  .mc-exp-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 8px; }
  .mc-chip { background: var(--surface); border: 1px solid var(--border2); color: var(--text2); font-size: 0.68rem; padding: 2px 9px; border-radius: 10px; }

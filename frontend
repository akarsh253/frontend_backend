<!-- ═══════════════════════════════════════
     FOUNDX INTRO ANIMATION
═══════════════════════════════════════ -->
<style>
#fx-intro {
  position: fixed; inset: 0; z-index: 99999;
  background: #000;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
  cursor: pointer;
}
#fx-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

/* skip hint */
#fx-skip {
  position: absolute; bottom: 28px; right: 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem; font-weight: 600;
  color: rgba(34,197,94,0.45);
  letter-spacing: 0.12em; text-transform: uppercase;
  z-index: 10; pointer-events: none;
  opacity: 0; animation: fxSkipIn 0.5s 1.8s ease forwards;
}
@keyframes fxSkipIn { to { opacity: 1; } }

#fx-intro.fx-out {
  animation: fxDismiss 0.65s ease forwards;
}
@keyframes fxDismiss {
  0%   { opacity:1; transform:scale(1); }
  100% { opacity:0; transform:scale(1.06); }
}
body.fx-lock { overflow: hidden; }
</style>

<div id="fx-intro">
  <canvas id="fx-canvas"></canvas>
  <div id="fx-skip">Click or press Esc to skip</div>
</div>

<script>
(function(){
  const overlay = document.getElementById('fx-intro');
  const canvas  = document.getElementById('fx-canvas');
  const ctx     = canvas.getContext('2d');
  document.body.classList.add('fx-lock');

  let W, H, cx, cy;
  function resize(){
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W/2; cy = H/2;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── colour palette ──────────────────────
  const GREEN       = '#22c55e';
  const GREEN_DARK  = '#16a34a';
  const GREEN_DIM   = 'rgba(34,197,94,';
  const WHITE       = 'rgba(232,245,233,';

  // ── timing (ms) ─────────────────────────
  const TOTAL_MS  = 4800;
  const FADE_MS   = 700;

  // ── stars ────────────────────────────────
  const STARS = [];
  for(let i=0;i<280;i++){
    STARS.push({
      x: Math.random(),
      y: Math.random(),
      r: Math.random()*1.4+0.2,
      a: Math.random()*0.6+0.1,
      twinkle: Math.random()*Math.PI*2
    });
  }

  // ── particles for explosion ───────────────
  class Particle {
    constructor(angle, speed, color, size, life){
      this.x   = cx; this.y = cy;
      this.vx  = Math.cos(angle)*speed;
      this.vy  = Math.sin(angle)*speed;
      this.color = color;
      this.size  = size;
      this.life  = life;   // 0→1 normalised age
      this.decay = 0.012 + Math.random()*0.018;
      this.alpha = 1;
      this.trail = [];
    }
    update(){
      this.trail.push({x:this.x,y:this.y});
      if(this.trail.length>6) this.trail.shift();
      this.x += this.vx; this.vy += 0.04;
      this.y += this.vy; this.vx *= 0.97;
      this.alpha -= this.decay;
    }
    draw(){
      if(this.alpha<=0) return;
      // trail
      for(let i=0;i<this.trail.length;i++){
        const a = (i/this.trail.length)*this.alpha*0.35;
        ctx.beginPath();
        ctx.arc(this.trail[i].x, this.trail[i].y, this.size*0.5, 0, Math.PI*2);
        ctx.fillStyle = this.color.replace(')',`,${a})`).replace('rgb','rgba');
        ctx.fill();
      }
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI*2);
      ctx.fillStyle = this.color.replace(')',`,${this.alpha})`).replace('rgb','rgba');
      ctx.fill();
    }
  }

  // ── shockwave rings ───────────────────────
  class Ring {
    constructor(delay, color, maxR, thickness){
      this.delay = delay; this.r = 0;
      this.maxR  = maxR;  this.color = color;
      this.thickness = thickness;
      this.age = -delay;
    }
    update(dt){ this.age += dt; }
    draw(){
      if(this.age < 0) return;
      const p = Math.min(this.age/900, 1);
      this.r = p * this.maxR;
      const alpha = (1-p)*0.7;
      if(alpha <= 0) return;
      ctx.beginPath();
      ctx.arc(cx, cy, this.r, 0, Math.PI*2);
      ctx.strokeStyle = this.color.replace('X', alpha);
      ctx.lineWidth   = this.thickness*(1-p*0.6);
      ctx.stroke();
    }
  }

  // ── arc strokes (orbiting brush marks) ───
  class ArcStroke {
    constructor(startAngle, sweep, radius, delay, speed, color){
      this.startAngle = startAngle;
      this.sweep      = sweep;
      this.radius     = radius;
      this.delay      = delay;
      this.speed      = speed;
      this.color      = color;
      this.progress   = 0;
      this.age        = -delay;
      this.rot        = 0;
    }
    update(dt){
      this.age += dt;
      if(this.age < 0) return;
      this.progress = Math.min(this.progress + dt*this.speed*0.001, 1);
      this.rot += dt * 0.00015;
    }
    draw(){
      if(this.progress <= 0) return;
      const drawn = this.sweep * this.progress;
      ctx.beginPath();
      ctx.arc(cx, cy, this.radius, this.startAngle+this.rot, this.startAngle+this.rot+drawn);
      ctx.strokeStyle = this.color;
      ctx.lineWidth   = 2.5;
      ctx.lineCap     = 'round';
      ctx.stroke();
    }
  }

  // ── crosshair ────────────────────────────
  function drawCrosshair(alpha, scale){
    const s  = 26*scale;
    const g  = 8*scale;
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.strokeStyle = GREEN;
    ctx.lineWidth   = 1.5;
    ctx.lineCap     = 'round';
    // vertical
    ctx.beginPath(); ctx.moveTo(cx, cy-s); ctx.lineTo(cx, cy-g);
    ctx.moveTo(cx, cy+g); ctx.lineTo(cx, cy+s); ctx.stroke();
    // horizontal
    ctx.beginPath(); ctx.moveTo(cx-s, cy); ctx.lineTo(cx-g, cy);
    ctx.moveTo(cx+g, cy); ctx.lineTo(cx+s, cy); ctx.stroke();
    // dot
    ctx.beginPath(); ctx.arc(cx, cy, 2*scale, 0, Math.PI*2);
    ctx.fillStyle = GREEN; ctx.fill();
    ctx.restore();
  }

  // ── glowing text ─────────────────────────
  function drawLogo(alpha, scale){
    if(alpha <= 0) return;
    ctx.save();
    ctx.globalAlpha = alpha;

    // glow layers
    const fontSize = Math.min(W*0.11, 90)*scale;
    ctx.font = `800 ${fontSize}px "Syne", sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    // outer glow
    ctx.shadowBlur  = 80; ctx.shadowColor = GREEN;
    ctx.fillStyle   = GREEN_DIM + '0.15)';
    ctx.fillText('FoundX', cx, cy);

    ctx.shadowBlur  = 40; ctx.shadowColor = GREEN;
    ctx.fillStyle   = GREEN_DIM + '0.4)';
    ctx.fillText('FoundX', cx, cy);

    // solid
    ctx.shadowBlur  = 18; ctx.shadowColor = GREEN;
    ctx.fillStyle   = '#e8f5e9';
    ctx.fillText('Found', cx - fontSize*0.18, cy);

    // X in green
    ctx.shadowBlur  = 24; ctx.shadowColor = GREEN;
    ctx.fillStyle   = GREEN;
    // measure "Found" to position X
    const foundW = ctx.measureText('Found').width;
    const xW     = ctx.measureText('X').width;
    ctx.fillText('X', cx + foundW*0.5 - xW*0.1, cy);

    ctx.restore();
  }

  function drawTagline(alpha){
    if(alpha<=0) return;
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.font = `500 ${Math.min(W*0.018, 15)}px "DM Sans", sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = GREEN_DIM+'0.8)';
    ctx.letterSpacing = '0.2em';
    ctx.fillText('WHERE FOUNDERS BEGIN', cx, cy + Math.min(W*0.07,64));
    ctx.restore();
  }

  function drawUnderline(alpha, progress){
    if(alpha<=0||progress<=0) return;
    const maxW = Math.min(W*0.28, 260);
    const w    = maxW * progress;
    ctx.save();
    ctx.globalAlpha = alpha;
    const grad = ctx.createLinearGradient(cx-w/2, 0, cx+w/2, 0);
    grad.addColorStop(0,   'rgba(34,197,94,0)');
    grad.addColorStop(0.5, GREEN);
    grad.addColorStop(1,   'rgba(34,197,94,0)');
    ctx.fillStyle   = grad;
    ctx.shadowBlur  = 12; ctx.shadowColor = GREEN;
    ctx.fillRect(cx-w/2, cy+Math.min(W*0.055,50), w, 2);
    ctx.restore();
  }

  // ── scene objects ─────────────────────────
  const particles = [];
  let   burstDone = false;

  const rings = [
    new Ring(0,   'rgba(34,197,94,X)', Math.min(W,H)*0.55, 3),
    new Ring(120, 'rgba(34,197,94,X)', Math.min(W,H)*0.40, 2),
    new Ring(240, 'rgba(100,230,140,X)', Math.min(W,H)*0.30, 1.5),
  ];

  const radius = Math.min(W,H)*0.22;
  const arcs = [
    new ArcStroke(Math.PI*0.15,  Math.PI*0.7,  radius,      200, 2.2, GREEN_DIM+'0.9)'),
    new ArcStroke(Math.PI*1.05,  Math.PI*0.65, radius,      350, 1.9, GREEN_DIM+'0.7)'),
    new ArcStroke(-Math.PI*0.3,  Math.PI*0.4,  radius*1.08, 500, 1.6, GREEN_DIM+'0.5)'),
    new ArcStroke(Math.PI*0.8,   Math.PI*0.35, radius*0.92, 650, 2.0, GREEN_DIM+'0.6)'),
  ];

  // ── animation loop ────────────────────────
  let   start = null;
  let   last  = null;
  let   done  = false;

  function ease(t){ return t<0.5 ? 2*t*t : -1+(4-2*t)*t; }
  function clamp(v,a,b){ return Math.max(a,Math.min(b,v)); }

  function frame(ts){
    if(done) return;
    if(!start){ start = ts; last = ts; }
    const elapsed = ts - start;
    const dt      = ts - last; last = ts;

    // clear
    ctx.clearRect(0,0,W,H);

    // ── starfield ──
    ctx.save();
    STARS.forEach(s => {
      s.twinkle += 0.02;
      const twinkleA = s.a * (0.7 + 0.3*Math.sin(s.twinkle));
      ctx.beginPath();
      ctx.arc(s.x*W, s.y*H, s.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(200,240,210,${twinkleA})`;
      ctx.fill();
    });
    ctx.restore();

    // ── burst particles at t=0 ──
    if(!burstDone && elapsed > 0){
      for(let i=0;i<120;i++){
        const ang   = Math.random()*Math.PI*2;
        const speed = 2 + Math.random()*7;
        const col   = Math.random()<0.7 ? 'rgb(34,197,94)' : 'rgb(180,255,180)';
        particles.push(new Particle(ang, speed, col, Math.random()*3+0.5, 1));
      }
      // secondary softer burst
      for(let i=0;i<60;i++){
        const ang   = Math.random()*Math.PI*2;
        const speed = 1 + Math.random()*4;
        particles.push(new Particle(ang, speed, 'rgb(100,220,130)', Math.random()*2+0.5, 1));
      }
      burstDone = true;
    }

    // ── rings ──
    rings.forEach(r => { r.update(dt); r.draw(); });

    // ── particles ──
    particles.forEach(p => { p.update(); p.draw(); });

    // ── arcs (start at 300ms) ──
    if(elapsed > 300) arcs.forEach(a => { a.update(dt); a.draw(); });

    // ── crosshair: fade in 0→400ms, hold, fade at logo reveal ──
    const xhAlpha = elapsed < 400
      ? clamp(elapsed/200, 0, 1)
      : elapsed < 900
        ? 1
        : clamp(1-(elapsed-900)/400, 0, 1);
    drawCrosshair(xhAlpha, 1);

    // ── logo: fade in 800ms→1300ms ──
    const logoProgress = clamp((elapsed-800)/500, 0, 1);
    const logoScale    = 0.8 + 0.2*ease(logoProgress);
    drawLogo(ease(logoProgress), logoScale);

    // ── underline: 1200ms→1800ms ──
    const lineAlpha = clamp((elapsed-1200)/300, 0, 1);
    const lineP     = clamp((elapsed-1200)/600, 0, 1);
    drawUnderline(lineAlpha, lineP);

    // ── tagline: 1600ms→2100ms ──
    const tagAlpha = clamp((elapsed-1600)/500, 0, 1);
    drawTagline(ease(tagAlpha));

    // ── ambient green core glow ──
    if(elapsed > 600){
      const gp   = clamp((elapsed-600)/400, 0, 1);
      const grad = ctx.createRadialGradient(cx,cy,0, cx,cy, Math.min(W,H)*0.18);
      grad.addColorStop(0,   `rgba(34,197,94,${0.12*ease(gp)})`);
      grad.addColorStop(0.5, `rgba(34,197,94,${0.04*ease(gp)})`);
      grad.addColorStop(1,   'rgba(34,197,94,0)');
      ctx.save(); ctx.globalCompositeOperation = 'screen';
      ctx.fillStyle = grad;
      ctx.fillRect(0,0,W,H);
      ctx.restore();
    }

    // ── FADE OUT at TOTAL_MS - FADE_MS ──
    if(elapsed >= TOTAL_MS - FADE_MS && elapsed < TOTAL_MS){
      const fp = (elapsed-(TOTAL_MS-FADE_MS))/FADE_MS;
      ctx.save();
      ctx.globalAlpha = fp;
      ctx.fillStyle   = '#000';
      ctx.fillRect(0,0,W,H);
      ctx.restore();
    }

    if(elapsed >= TOTAL_MS){
      dismiss(); return;
    }

    requestAnimationFrame(frame);
  }

  function dismiss(){
    if(done) return; done = true;
    overlay.classList.add('fx-out');
    document.body.classList.remove('fx-lock');
    setTimeout(()=>{ overlay.style.display='none'; }, 700);
  }

  // skip
  overlay.addEventListener('click', dismiss);
  document.addEventListener('keydown', e=>{
    if(e.key==='Escape'||e.key===' ') dismiss();
  }, {once:true});

  requestAnimationFrame(frame);
})();
</script>


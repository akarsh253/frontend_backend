    font-size: 2rem; flex-shrink: 0;
  }
  .mpm-action-btns { display: flex; gap: 8px; padding-bottom: 4px; }
  .mpm-btn-primary {
    background: var(--green); color: #000; border: none;
    padding: 9px 20px; border-radius: 8px;
    font-family: 'Syne', sans-serif; font-size: 0.82rem; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
  }
  .mpm-btn-primary:hover { background: var(--green-dark); }
  .mpm-btn-sec {
    background: none; color: var(--text); border: 1.5px solid var(--border2);
    padding: 8px 16px; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-size: 0.82rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s;
  }
  .mpm-btn-sec:hover { border-color: var(--green); color: var(--green); }

  .mpm-body { padding: 16px 28px 28px; }
  .mpm-name { font-family: 'Syne', sans-serif; font-size: 1.3rem; font-weight: 800; color: var(--text); margin-bottom: 3px; display: flex; align-items: center; gap: 8px; }
  .mpm-title { font-size: 0.85rem; color: var(--text2); margin-bottom: 14px; }

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FoundX</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #0a0f0a;
        --surface: #111811;
        --green: #22c55e;
        --green-dark: #16a34a;
        --green-glow: #22c55e33;
        --green-faint: #22c55e11;
        --text: #e8f5e9;
        --muted: #6b7f6b;
        --border: #1e2d1e;
        --card-bg: #0f1a0f;
        --red: #ef4444;
        --red-faint: #ef444411;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
      }
      body::before {
        content: "";
        position: fixed;
        top: -200px;
        left: -200px;
        width: 700px;
        height: 700px;
        background: radial-gradient(circle, #22c55e18 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }
      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
        height: 64px;
        background: rgba(10, 15, 10, 0.85);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .logo {
        font-family: "Syne", sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: var(--text);
        cursor: pointer;
      }
      .logo span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--green);
        color: #000;
        font-weight: 800;
        font-size: 1rem;
        width: 26px;
        height: 26px;
        border-radius: 5px;
        margin-left: 1px;
        vertical-align: middle;
        position: relative;
        top: -1px;
      }
      .nav-actions {
        display: flex;
        gap: 12px;
        align-items: center;
      }
      .btn-outline {
        border: 1.5px solid var(--green);
        color: var(--green);
        background: transparent;
        padding: 8px 22px;
        border-radius: 24px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
      }
      .btn-outline:hover {
        background: var(--green-faint);
      }
      .btn-solid {
        background: var(--green);
        color: #000;
        border: none;
        padding: 8px 22px;
        border-radius: 24px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.875rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
      }
      .btn-solid:hover {
        background: var(--green-dark);
      }
      .hero {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        min-height: calc(100vh - 64px);
        max-width: 1280px;
        margin: 0 auto;
        padding: 60px 48px;
        gap: 64px;
      }
      .hero-left {
        animation: fadeUp 0.7s ease both;
      }
      .video-hero{position: absolute; top: 13%; left: 50%; transform: translate(-50%); width: 500vw; height: 115vh; object-fit: cover; z-index: -1;
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      h1 {
        font-family: "Syne", sans-serif;
        font-size: clamp(2.6rem, 4vw, 3.6rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -1.5px;
        color: var(--text);
        margin-bottom: 36px;
      }
      h1 em {
        font-style: normal;
        color: var(--green);
      }
      .auth-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-width: 420px;
      }
      .auth-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        padding: 14px 20px;
        border-radius: 8px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
      }
      .auth-btn.google {
        background: var(--green);
        color: #000;
        font-weight: 700;
      }
      .auth-btn.google:hover {
        background: var(--green-dark);
        transform: translateY(-1px);
        box-shadow: 0 8px 32px var(--green-glow);
      }
      .auth-btn.microsoft {
        background: transparent;
        color: var(--text);
        border: 1.5px solid var(--border);
      }
      .auth-btn.microsoft:hover {
        border-color: var(--green);
        background: var(--green-faint);
      }
      .auth-btn.email {
        background: var(--card-bg);
        color: var(--text);
        border: 1.5px solid var(--border);
      }
      .auth-btn.email:hover {
        border-color: var(--green);
      }
      .user-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--green), #166534);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #000;
        position: relative;
      }
      .notif-dot {
        position: absolute;
        top: -3px;
        right: -3px;
        background: #ef4444;
        color: #fff;
        font-size: 0.55rem;
        font-weight: 700;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid var(--bg);
      }
      .email-chevron {
        margin-left: auto;
        color: var(--muted);
        font-size: 1rem;
      }
      .legal {
        font-size: 0.75rem;
        color: var(--muted);
        margin-top: 16px;
        line-height: 1.6;
        max-width: 420px;
      }
      .legal a {
        color: var(--green);
        text-decoration: none;
      }
      .join-link {
        margin-top: 24px;
        font-size: 0.9rem;
        color: var(--muted);
      }
      .join-link a {
        color: var(--green);
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
      }
      .hero-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 10px;
      }
      .g-icon,
      .ms-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
      }
      .toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        max-width: 300px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
        animation: slideUp 0.5s 1s ease both;
        z-index: 200;
      }
      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .toast-icon {
        background: var(--green);
        color: #000;
        font-weight: 800;
        font-size: 0.75rem;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .toast-body {
        flex: 1;
      }
      .toast-title {
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--text);
        margin-bottom: 2px;
      }
      .toast-sub {
        font-size: 0.75rem;
        color: var(--muted);
        margin-bottom: 10px;
      }
      .toast-cta {
        display: inline-block;
        border: 1.5px solid var(--green);
        color: var(--green);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.2s;
        background: transparent;
        font-family: "DM Sans", sans-serif;
      }
      .toast-cta:hover {
        background: var(--green-faint);
      }
      .toast-close {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1rem;
        padding: 0;
        line-height: 1;
        flex-shrink: 0;
      }
      .err-toast {
        position: fixed;
        top: 80px;
        right: 28px;
        background: #1a0606;
        border: 1px solid var(--red);
        border-radius: 10px;
        padding: 12px 18px;
        color: #fca5a5;
        font-size: 0.85rem;
        font-weight: 500;
        z-index: 900;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        display: none;
        max-width: 320px;
        align-items: center;
        gap: 10px;
      }
      .err-toast.show {
        display: flex;
        animation: slideDown 0.3s ease;
      }
      .suc-toast {
        position: fixed;
        top: 80px;
        right: 28px;
        background: #061a09;
        border: 1px solid #22c55e50;
        border-radius: 10px;
        padding: 12px 18px;
        color: #86efac;
        font-size: 0.85rem;
        font-weight: 500;
        z-index: 900;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        display: none;
        max-width: 320px;
        align-items: center;
        gap: 10px;
      }
      .suc-toast.show {
        display: flex;
        animation: slideDown 0.3s ease;
      }
      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 500;
        backdrop-filter: blur(12px) brightness(0.45);
        background: rgba(5, 10, 5, 0.55);
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .modal-overlay.open {
        display: flex;
        animation: overlayIn 0.25s ease both;
      }
      @keyframes overlayIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      .modal-card {
        position: relative;
        background: #0f160f;
        border: 1px solid #1e2d1e;
        border-radius: 20px;
        padding: 36px 36px 28px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
        animation: cardIn 0.35s cubic-bezier(0.34, 1.4, 0.64, 1) both;
        max-height: 92vh;
        overflow-y: auto;
      }
      @keyframes cardIn {
        from {
          opacity: 0;
          transform: scale(0.92) translateY(20px);
        }
        to {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }
      .modal-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        border-radius: 20px 20px 0 0;
        background: linear-gradient(
          90deg,
          transparent,
          var(--green),
          transparent
        );
        opacity: 0.7;
      }
      .modal-close {
        position: absolute;
        top: 16px;
        right: 18px;
        background: none;
        border: none;
        color: var(--muted);
        font-size: 1.2rem;
        cursor: pointer;
        transition: color 0.2s;
        line-height: 1;
        padding: 4px;
      }
      .modal-close:hover {
        color: var(--text);
      }
      .modal-logo {
        font-family: "Syne", sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 2px;
      }
      .modal-logo span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--green);
        color: #000;
        font-size: 0.75rem;
        font-weight: 800;
        width: 22px;
        height: 22px;
        border-radius: 5px;
      }
      .modal-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 22px;
        background: #0d150d;
        border-radius: 10px;
        padding: 4px;
      }
      .modal-tab {
        flex: 1;
        padding: 9px;
        border: none;
        background: none;
        color: var(--muted);
        font-family: "DM Sans", sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        border-radius: 7px;
        transition: all 0.2s;
      }
      .modal-tab.active {
        background: #1a2d1a;
        color: var(--green);
      }
      .tab-pane {
        display: none;
      }
      .tab-pane.active {
        display: block;
      }
      .modal-card h2 {
        font-family: "Syne", sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.8px;
        margin-bottom: 18px;
      }
      .m-auth-btn {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 12px 16px;
        border-radius: 10px;
        border: 1.5px solid #1e2d1e;
        background: #111811;
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 8px;
        gap: 12px;
      }
      .m-auth-btn:hover {
        border-color: var(--green);
        background: #22c55e0d;
        transform: translateY(-1px);
      }
      .m-auth-btn.google-m,
      .m-auth-btn.apple-m {
        justify-content: center;
      }
      .m-legal {
        font-size: 0.71rem;
        color: var(--muted);
        line-height: 1.6;
        margin-bottom: 14px;
      }
      .m-legal a {
        color: var(--green);
        text-decoration: none;
      }
      .m-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
      }
      .m-divider hr {
        flex: 1;
        border: none;
        border-top: 1px solid #1e2d1e;
      }
      .m-divider span {
        font-size: 0.78rem;
        color: var(--muted);
        font-weight: 500;
      }
      .m-input-group {
        position: relative;
        margin-bottom: 8px;
      }
      .m-input-group input {
        width: 100%;
        padding: 12px 16px;
        background: #0d150d;
        border: 1.5px solid #1e2d1e;
        border-radius: 10px;
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 0.88rem;
        outline: none;
        transition: all 0.2s;
      }
      .m-input-group input::placeholder {
        color: var(--muted);
      }
      .m-input-group input:focus {
        border-color: var(--green);
        box-shadow: 0 0 0 3px #22c55e18;
        background: #0f1c0f;
      }
      .m-show-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--green);
        font-family: "DM Sans", sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        padding: 0;
      }
      .m-forgot {
        display: inline-block;
        color: var(--green);
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 12px;
      }
      .m-checkbox-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
      }
      .m-checkbox-row input[type="checkbox"] {
        appearance: none;
        width: 17px;
        height: 17px;
        border: 2px solid #1e2d1e;
        border-radius: 4px;
        background: #0d150d;
        cursor: pointer;
        position: relative;
        transition: all 0.2s;
        flex-shrink: 0;
      }
      .m-checkbox-row input[type="checkbox"]:checked {
        background: var(--green);
        border-color: var(--green);
      }
      .m-checkbox-row input[type="checkbox"]:checked::after {
        content: "✓";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #000;
        font-size: 0.65rem;
        font-weight: 900;
      }
      .m-checkbox-row label {
        font-size: 0.84rem;
        color: var(--text);
        cursor: pointer;
        user-select: none;
        line-height: 1.4;
      }
      .m-submit-btn {
        width: 100%;
        padding: 13px;
        background: var(--green);
        color: #000;
        border: none;
        border-radius: 10px;
        font-family: "Syne", sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s;
        margin-bottom: 18px;
        position: relative;
        overflow: hidden;
      }
      .m-submit-btn:hover {
        background: var(--green-dark);
        box-shadow: 0 6px 28px #22c55e30;
        transform: translateY(-1px);
      }
      .m-submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }
      .m-footer {
        text-align: center;
        font-size: 0.82rem;
        color: var(--muted);
        border-top: 1px solid #1e2d1e;
        padding-top: 16px;
      }
      .m-footer a {
        color: var(--green);
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
      }
      .pw-strength {
        display: flex;
        gap: 4px;
        margin-top: 4px;
        margin-bottom: 3px;
      }
      .pw-seg {
        flex: 1;
        height: 3px;
        border-radius: 2px;
        background: #1e2d1e;
        transition: background 0.3s;
      }
      .pw-seg.weak {
        background: #ef4444;
      }
      .pw-seg.medium {
        background: #f59e0b;
      }
      .pw-seg.strong {
        background: var(--green);
      }
      .pw-label {
        font-size: 0.68rem;
        color: var(--muted);
        margin-bottom: 8px;
      }
      .m-name-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }
      .spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(0, 0, 0, 0.3);
        border-top-color: #000;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        display: inline-block;
        vertical-align: middle;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      /* footer */
      .footer-illustration {
        width: 100%;
        background: linear-gradient(180deg, var(--bg) 0%, #071209 100%);
        border-top: 1px solid var(--border);
        overflow: hidden;
        position: relative;
      }
      .footer-illustration::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse at 50% 40%,
          #22c55e12 0%,
          transparent 70%
        );
        pointer-events: none;
      }
      .footer-illus-inner {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 48px;
        padding: 64px 48px 48px;
      }
      .footer-illus-text h2 {
        font-family: "Syne", sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.8rem);
        font-weight: 800;
        letter-spacing: -1px;
        color: var(--text);
        line-height: 1.15;
        margin-bottom: 16px;
      }
      .footer-illus-text h2 em {
        font-style: normal;
        color: var(--green);
      }
      .footer-illus-text p {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 400px;
        margin-bottom: 28px;
      }
      .footer-illus-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--green);
        color: #000;
        padding: 12px 28px;
        border-radius: 28px;
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: all 0.25s;
      }
      .footer-illus-cta:hover {
        background: var(--green-dark);
        transform: translateY(-2px);
      }
      .footer-illus-img img {
        width: 100%;
        max-width: 540px;
        border-radius: 20px;
      }
      .site-footer {
        background: #060c06;
        border-top: 1px solid var(--border);
        padding: 48px 0 0;
      }
      .footer-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 48px;
      }
      .footer-top {
        display: grid;
        grid-template-columns: 180px repeat(4, 1fr);
        gap: 40px;
        padding-bottom: 40px;
      }
      .footer-brand p {
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.6;
        max-width: 160px;
        margin-top: 8px;
      }
      .footer-col h4 {
        font-family: "Syne", sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 14px;
      }
      .footer-col ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 9px;
      }
      .footer-col ul li a {
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-col ul li a:hover {

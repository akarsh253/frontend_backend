  /* ══════════════════════
     MENTOR DASHBOARD
  ══════════════════════ */
  .mentor-dashboard {
    display: none; max-width: 1100px; margin: 0 auto; padding: 28px 20px;
  }
  .mentor-dashboard.show { display: block; }
  .mdb-header { margin-bottom: 24px; }

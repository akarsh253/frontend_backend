  neha:   { avatar:'👩‍💼', name:'Neha Gupta',    college:'BBA Marketing · Central University of Jammu · 2026', about:'Digital marketing specialist with a passion for EdTech and community-led growth. Managed social media for 3 student startups, collectively reaching 80K+ followers.', skills:[['Digital Marketing','85%',85],['SEO/SEM','75%',75],['Content Writing','88%',88],['Growth','70%',70]] },
};

function openTalentProfile(id) {
  const t = talentData[id] || talentData.rahul;
  document.getElementById('tppAvatar').textContent = t.avatar;
  document.getElementById('tppName').textContent = t.name;
  document.getElementById('tppCollege').textContent = t.college;
  document.getElementById('tppAbout').textContent = t.about;

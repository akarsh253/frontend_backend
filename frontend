});

// Talent profile drawer
const talentData = {
  rahul:  { avatar:'👨‍💻', name:'Rahul Sharma',  college:'BTech CSE · IIT Delhi · Class of 2026', about:'Passionate software developer interested in building AI-powered products and solving real-world problems. Open to early-stage startup internships in AI or SaaS.', skills:[['React','90%',90],['Node.js','80%',80],['Python/ML','75%',75],['MongoDB','70%',70]] },

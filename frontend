  .mpm-section { margin-top: 20px; border-top: 1px solid var(--border); padding-top: 18px; }
  .mpm-section-title { font-family: 'Syne', sans-serif; font-size: 0.82rem; font-weight: 800; color: var(--text); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }

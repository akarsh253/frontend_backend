    const resourcesPageRef = document.getElementById('resources-page');
    const map = {
      'Home':      feedLayout,
      'Mentors':   mentorsPage,
      'Startups':  startupsPage,
      'Talent':    talentPage,
      'Events':    eventsPage,
      'Resources': resourcesPageRef,
    };
    // hide all secondary pages
    [mentorsPage, startupsPage, talentPage, eventsPage, resourcesPageRef].forEach(p => { if(p) p.style.display = 'none'; });
    feedLayout.style.display = 'none';
    if (map[lbl]) {
      map[lbl].style.display = 'block';
      if (lbl === 'Resources') { setTimeout(animateTrendingBarsDeferred, 300); }

  .mc-actions { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; flex-shrink: 0; }
  .mc-rating { font-size: 0.78rem; color: var(--gold); font-weight: 700; margin-bottom: 4px; text-align: right; }
  .mc-btn-primary {

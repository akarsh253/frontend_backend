  // ── MENTOR PROFILE MODAL ──
  const mentorData = {
    sarah: { name: 'Sarah Johnson', title: 'Product Leader at Google · 15+ years', loc: 'San Francisco, USA', avatar: '👩‍💼', about: 'Former startup founder with 15+ years in SaaS and product growth. Built and scaled products to 10M+ users. 3 successful exits including an acquisition by Salesforce. Passionate about helping early-stage founders avoid the mistakes I made.' },
    alex:  { name: 'Alex Chen',     title: 'Partner at Sequoia India · 12+ years', loc: 'Mumbai, India',    avatar: '👨‍💻', about: 'Investor and former founder with deep expertise in FinTech and growth-stage startups. I\'ve evaluated 1,000+ pitches and backed 40+ companies. Help founders with fundraising, pitch storytelling, and term sheet navigation.' },
    priya: { name: 'Priya Nair',    title: 'CEO at HealthBridge · Ex-McKinsey · 10+ years', loc: 'Bangalore, India', avatar: '👩‍🔬', about: 'Healthcare entrepreneur and strategy consultant. Built HealthBridge from zero to 500+ hospital partnerships. Specialise in B2B GTM, regulatory navigation, and enterprise sales in healthcare and life sciences.' },
    rajan: { name: 'Rajan Kapoor',  title: 'Serial Founder · 3 Exits · Investor at 100X.vc', loc: 'Mumbai, India', avatar: '🧑‍🚀', about: '3x founder with exits to Flipkart, PhonePe, and a NYSE-listed firm. Now an active angel investor backing pre-seed to Series A startups. Passionate about first-principles thinking and helping founders find PMF fast.' },
    ananya:{ name: 'Ananya Sharma', title: 'VP Engineering at Razorpay · Ex-Google Brain', loc: 'Bangalore, India', avatar: '👩‍🎓', about: 'Engineering leader with deep roots in AI/ML systems and high-scale infrastructure. Helped Razorpay scale from 50 to 800+ engineers. I mentor technical founders on building world-class engineering orgs and AI product development.' },
    vikram:{ name: 'Vikram Bose',   title: 'Co-Founder & CMO at GrowthLoop · YC W22', loc: 'Delhi, India', avatar: '👨‍💼', about: 'Growth marketer and community builder. Scaled GrowthLoop to 2M users with a $0 paid budget. I help founders understand viral loops, retention mechanics, and building a brand from day zero.' },
    meera: { name: 'Dr. Meera Iyer', title: 'Founder at MedTechIndia · Ex-AIIMS Researcher', loc: 'Chennai, India', avatar: '👩‍⚕️', about: 'Clinical researcher turned entrepreneur. Founded MedTechIndia to democratise diagnostics in Tier-2 India. Expertise in navigating CDSCO regulations, clinical validation, and hospital partnerships.' },
  };

  function openMentorProfile(id) {
    const m = mentorData[id] || mentorData.sarah;
    currentMentorName = m.name;
    document.getElementById('mpmAvatar').textContent = m.avatar;
    document.getElementById('mpmName').innerHTML = m.name + ' <span class="mc-verified" style="font-size:0.6rem;">✓</span>';
    document.getElementById('mpmTitle').textContent = m.title;
    document.getElementById('mpmLoc').textContent = m.loc;
    document.getElementById('mpmAbout').textContent = m.about;
    document.getElementById('mentorProfileModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeMentorProfile() {
    document.getElementById('mentorProfileModal').classList.remove('open');
    document.body.style.overflow = '';
  }
  function handleMentorModalClick(e) {
    if (e.target === document.getElementById('mentorProfileModal')) closeMentorProfile();
  }

  // ── REQUEST MODAL ──
  function openRequestModal(mentorName) {
    currentMentorName = mentorName;
    document.getElementById('rmSub').textContent = 'Sending request to ' + mentorName;
    document.getElementById('mentorProfileModal').classList.remove('open');
    document.getElementById('requestModalOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeRequestModal() {
    document.getElementById('requestModalOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }
  function handleRequestOverlayClick(e) {
    if (e.target === document.getElementById('requestModalOverlay')) closeRequestModal();
  }
  function submitRequest() {
    closeRequestModal();
    // simple toast feedback
    const t = document.createElement('div');
    t.style.cssText = 'position:fixed;bottom:28px;right:28px;background:#0f2e15;border:1px solid #22c55e40;border-radius:12px;padding:14px 20px;color:#e8f5e9;font-size:0.85rem;font-weight:600;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.5);animation:slideUp 0.3s ease;display:flex;align-items:center;gap:10px;';
    t.innerHTML = '<span style="background:var(--green,#22c55e);color:#000;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:900;flex-shrink:0;">✓</span> Request sent to ' + currentMentorName + '!';
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3500);
  }

  // ── MENTOR DASHBOARD ──
  function showMentorDashboard() {
    const db = document.getElementById('mentor-dashboard');
    db.classList.toggle('show');
    db.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function hideMentorDashboard() {
    document.getElementById('mentor-dashboard').classList.remove('show');
  }

  // ── LIKE TOGGLE ──
  document.querySelectorAll('.action-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      if (this.textContent.trim().startsWith('Celebrate') || this.textContent.trim().startsWith('Support')) {
        this.classList.toggle('liked');
      }
    });
  });

  // ── COMPOSER ──
  const composerInput = document.querySelector('.composer-input');
  if (composerInput) {
    composerInput.addEventListener('click', function() {
      this.style.background = 'var(--surface2)';
      setTimeout(() => this.style.background = '', 600);
    });
  }

  // ── ESCAPE KEY ──
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closeMentorProfile();
      closeRequestModal();
      if(typeof closeStartupProfile === 'function') closeStartupProfile();
      if(typeof closeAddStartupModal === 'function') closeAddStartupModal();
    }
  });
</script>



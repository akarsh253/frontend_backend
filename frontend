  .ai-rec-btn:hover { background: var(--green); color: #000; }

  /* ── SUCCESS STORIES ── */
  .success-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .success-card {
    background: var(--surface); border: 1px solid var(--border);

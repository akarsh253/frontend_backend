      // ─── localStorage DB ─────────────────────────────────────
      const DB = {
        getUsers() {
          try {
            return JSON.parse(localStorage.getItem("foundx_users") || "[]");
          } catch {
            return [];
          }
        },
        saveUsers(u) {
          localStorage.setItem("foundx_users", JSON.stringify(u));
        },
        getSession() {
          try {
            return JSON.parse(localStorage.getItem("foundx_current") || "null");
          } catch {
            return null;
          }
        },
        setSession(s) {
          localStorage.setItem("foundx_current", JSON.stringify(s));
        },
        hash(str) {
          let h = 0;
          for (let i = 0; i < str.length; i++) {
            h = (h << 5) - h + str.charCodeAt(i);
            h |= 0;
          }
          return h.toString(36);
        },

        register(firstName, lastName, email, password, jobTitle = "") {
          const users = this.getUsers();
          if (users.find((u) => u.email.toLowerCase() === email.toLowerCase()))
            return {
              ok: false,
              msg: "An account with this email already exists.",
            };
          if (password.length < 6)
            return {
              ok: false,
              msg: "Password must be at least 6 characters.",
            };
          const user = {
            id: Date.now().toString(),
            firstName,
            lastName,
            email,
            passwordHash: this.hash(password),
            jobTitle,
            provider: "email",
            loginCount: 0,
            createdAt: new Date().toISOString(),
          };
          users.push(user);
          this.saveUsers(users);
          return { ok: true, user };
        },

        signIn(email, password) {
          const users = this.getUsers();
          const user = users.find(
            (u) => u.email.toLowerCase() === email.toLowerCase(),
          );
          if (!user)
            return {
              ok: false,
              msg: "No account found with this email. Please join first.",
            };
          if (user.provider !== "email")
            return {
              ok: false,
              msg: `This account uses ${user.provider} sign-in. Please use that button above.`,
            };
          if (user.passwordHash !== this.hash(password))
            return { ok: false, msg: "Incorrect password. Please try again." };
          user.loginCount = (user.loginCount || 0) + 1;
          this.saveUsers(users);
          const s = {
            userId: user.id,
            email: user.email,
            name: user.firstName + " " + user.lastName,
            firstName: user.firstName,
            lastName: user.lastName,
            jobTitle: user.jobTitle || "",

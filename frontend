  priya:  { avatar:'👩‍🎨', name:'Priya Verma',   college:'BDes · NID Ahmedabad · Class of 2026',   about:'Product designer obsessed with creating intuitive and beautiful interfaces. Specialize in design systems and motion design. Previously interned at Swiggy design team.', skills:[['Figma','95%',95],['UI/UX','90%',90],['Motion Design','78%',78],['Branding','72%',72]] },

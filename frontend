function getAiResponse(msg) {
  const lower = msg.toLowerCase();
  if (lower.includes('mvp') || lower.includes('build')) return aiResponses.mvp;
  if (lower.includes('investor') || lower.includes('pitch') || lower.includes('fund')) return aiResponses.investor;
  if (lower.includes('valid')) return aiResponses.validate;
  if (lower.includes('growth') || lower.includes('user') || lower.includes('market')) return aiResponses.growth;
  return aiResponses.default[0];
}


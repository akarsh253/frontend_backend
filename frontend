  }
  .become-mentor-section h3 { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .become-mentor-section p { font-size: 0.85rem; color: var(--text2); line-height: 1.6; margin-bottom: 20px; max-width: 400px; margin-left: auto; margin-right: auto; }
  .become-mentor-btn {
    background: var(--green); color: #000; border: none;
    padding: 12px 32px; border-radius: 28px;
    font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
  }
  .become-mentor-btn:hover { background: var(--green-dark); box-shadow: 0 8px 28px #22c55e30; transform: translateY(-1px); }

  /* ══════════════════════
     MENTOR PROFILE MODAL
  ══════════════════════ */
  .mentor-modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 600;
    background: rgba(4,8,4,0.85); backdrop-filter: blur(12px);
    align-items: flex-start; justify-content: center;
    padding: 20px; overflow-y: auto;
  }

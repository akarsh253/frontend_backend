  .fc-tags { display: flex; flex-wrap: wrap; gap: 4px; justify-content: center; margin-bottom: 10px; }
  .fc-tag { background: var(--green-faint); border: 1px solid #22c55e25; color: var(--green); font-size: 0.65rem; padding: 2px 8px; border-radius: 10px; }
  .fc-rating { font-size: 0.75rem; color: var(--gold); font-weight: 600; margin-bottom: 12px; }
  .fc-btn {
    width: 100%; padding: 8px; background: var(--green-faint); border: 1px solid #22c55e30;

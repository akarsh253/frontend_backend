<script>
const startupsPage = document.getElementById('startups-page');

// Extend nav switching for Startups
document.querySelectorAll('.nav-item').forEach(btn => {
  btn.addEventListener('click', function() {
    const label = this.textContent.trim();
    if (label === 'Startups') {
      feedLayout.style.display = 'none';
      mentorsPage.style.display = 'none';
      startupsPage.style.display = 'block';
      window.scrollTo(0, 0);
    } else if (label !== 'Mentors') {
      startupsPage.style.display = 'none';
    }
  });
});

// Quick pill toggle
document.querySelectorAll('.qpill').forEach(p => {
  p.addEventListener('click', function() {
    document.querySelectorAll('.qpill').forEach(x => x.classList.remove('active'));
    this.classList.add('active');
  });
});

// Startup data
const startupData = {
  payflow:    { logo:'💳', name:'PayFlow',    tagline:'Smart digital payments for small businesses', stage:'stage-mvp', stageLabel:'MVP Stage', industry:'FinTech', about:'PayFlow helps small retailers accept digital payments without expensive POS infrastructure. We\'re building a UPI + BNPL hybrid layer that works on any $10 Android phone, even offline. Our vision is to bring 60 million kirana stores into the digital economy by 2027.', stack:['React','Node.js','MongoDB','AWS','UPI API'] },
  aicoach:    { logo:'🧠', name:'CoachAI',   tagline:'Personalised AI coaching for competitive exam prep', stage:'stage-growth', stageLabel:'Early Growth', industry:'EdTech', about:'CoachAI is an adaptive AI tutor for JEE, NEET and UPSC. We analyse student performance patterns to generate personalised study plans, detect weak areas, and resolve doubts using fine-tuned LLMs in 8 Indian languages.', stack:['Python','React','FastAPI','AWS','OpenAI API'] },
  greengrid:  { logo:'⚡', name:'GreenGrid', tagline:'AI micro-grid management for rural communities', stage:'stage-idea', stageLabel:'Idea Stage', industry:'ClimaTech', about:'GreenGrid is building AI-powered micro-grid management software that reduces energy waste by 43% for rural communities. Currently deployed across 120 villages in Rajasthan and Madhya Pradesh with MNRE support.', stack:['Python','IoT','AWS IoT','React','TensorFlow'] },
  healthscan: { logo:'🩺', name:'HealthScan',tagline:'AI early cancer screening for underserved communities', stage:'stage-idea', stageLabel:'Idea Stage', industry:'Healthcare', about:'HealthScan uses multimodal AI combining X-ray imaging and blood biomarkers to detect cancer at early stages. Targeting Tier-2/3 cities with 0 radiologists — a 600M+ person problem in India alone.', stack:['Python','PyTorch','FastAPI','DICOM','MongoDB'] },
  chainvault: { logo:'⛓', name:'ChainVault',tagline:'Decentralised certificate verification for the world', stage:'stage-scaling', stageLabel:'Scaling', industry:'Blockchain', about:'ChainVault eliminates certificate fraud by storing academic and professional credentials on a permissioned blockchain. Live with 40 universities and 3 government bodies, processing 200K+ verifications/month.', stack:['Solidity','React','Node.js','IPFS','Polygon'] },
};

function openStartupProfile(id) {
  const s = startupData[id] || startupData.payflow;
  document.getElementById('spmLogo').textContent = s.logo;
  document.getElementById('spmName').textContent = s.name;
  document.getElementById('spmTagline').textContent = s.tagline;
  document.getElementById('spmBadges').innerHTML = `<span class="fsu-stage ${s.stage}">${s.stageLabel}</span><span class="fsu-stage" style="color:#38bdf8;border-color:#38bdf840;background:#38bdf80d;">${s.industry}</span>`;
  document.getElementById('spmAbout').textContent = s.about;
  document.getElementById('spmStack').innerHTML = s.stack.map(t => `<span class="spm-tech">${t}</span>`).join('');
  document.getElementById('startupProfileOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeStartupProfile() {
  document.getElementById('startupProfileOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
function handleStartupOverlayClick(e) {
  if (e.target === document.getElementById('startupProfileOverlay')) closeStartupProfile();
}

function openAddStartupModal() {
  document.getElementById('addStartupOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeAddStartupModal() {
  document.getElementById('addStartupOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
function handleAddStartupOverlayClick(e) {
  if (e.target === document.getElementById('addStartupOverlay')) closeAddStartupModal();
}
function submitStartup() {
  closeAddStartupModal();
  const t = document.createElement('div');
  t.style.cssText = 'position:fixed;bottom:28px;right:28px;background:#0f2e15;border:1px solid #22c55e40;border-radius:12px;padding:14px 20px;color:#e8f5e9;font-size:0.85rem;font-weight:600;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.5);display:flex;align-items:center;gap:10px;';
  t.innerHTML = '<span style="background:#22c55e;color:#000;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:900;flex-shrink:0;">✓</span> Startup submitted! We\'ll review within 24 hours.';
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3800);
}
</script>



